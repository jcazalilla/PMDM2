<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/detalle_personaje"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="15dp"
    android:orientation="vertical"
    tools:context=".DetallePersonaje">


    <TextView
        android:id="@+id/tv_personaje"
        style="@style/estilo_titulo_descripcion"
        android:layout_width="329dp"
        android:layout_height="68dp"
        app:layout_constraintBottom_toTopOf="@+id/iv_personaje"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <ImageView
        android:id="@+id/iv_personaje"
        android:layout_width="233dp"
        android:layout_height="228dp"

        android:layout_marginBottom="36dp"
        android:cropToPadding="true"


        android:foregroundGravity="center_horizontal|center_vertical"
        app:layout_constraintBottom_toTopOf="@+id/tv_habilidades"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_personaje"
        app:layout_constraintVertical_bias="0.5" />

    <TextView
        android:id="@+id/tv_personaje_descripcion"
        style="@style/estilo_descripcion"
        android:layout_width="361dp"
        android:layout_height="99dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:gravity="left"
        app:layout_constraintBottom_toTopOf="@+id/btn_volver"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_habilidades" />

    <TextView
        android:id="@+id/tv_habilidades"
        style="@style/estilo_habilidades"
        android:layout_width="358dp"
        android:layout_height="136dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_personaje_descripcion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.476"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_personaje"
        app:layout_constraintVertical_bias="0.5" />

    <Button
        android:id="@+id/btn_volver"
        android:layout_width="116dp"
        android:layout_height="63dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:text="Volver"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>